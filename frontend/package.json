{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "RUN_DB_INTEGRATION_TESTS=true vitest run",
    "test:smoke": "vitest run test/login-page.test.tsx test/register-page.test.tsx test/case-detail-page.test.tsx",
    "audit:unused": "knip --config knip.json --reporter compact --exclude exports,types,nsExports,nsTypes,classMembers,enumMembers",
    "validate:full": "npm run lint && npm run type-check && npm run build"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@google-cloud/storage": "^7.19.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next": "15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-error-boundary": "^6.1.1",
    "resend": "^6.12.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "jsdom": "^24.1.3",
    "knip": "^5.63.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.10",
    "esbuild": "^0.25.0"
  }
}
